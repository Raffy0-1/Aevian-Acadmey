# Aevian — Environment Variables
# Copy this to .env and fill in your values.

# ─── Supabase Postgres (Prisma) ─────────────────────────────────────
# Direct connection — used by Prisma CLI for migrations/introspection.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:YOUR-PASSWORD@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# Pooled connection — used by the app at runtime.
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:YOUR-PASSWORD@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Supabase Client ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
